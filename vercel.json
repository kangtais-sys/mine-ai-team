{
  "crons": [
    {
      "path": "/api/cron/upload-pipeline",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cs/daily-report",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/instagram-comments",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/instagram-comments",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/instagram-comments",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/instagram-comments",
      "schedule": "0 13 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/auth/google", "destination": "/api/auth/google" },
    { "source": "/api/auth/google-callback", "destination": "/api/auth/google-callback" },
    { "source": "/api/auth/google-status", "destination": "/api/auth/google-status" },
    { "source": "/api/auth/tiktok", "destination": "/api/auth/tiktok" },
    { "source": "/api/auth/tiktok-callback", "destination": "/api/auth/tiktok-callback" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/orchestrate", "destination": "/api/orchestrate" },
    { "source": "/api/briefing", "destination": "/api/briefing" },
    { "source": "/api/upload-status", "destination": "/api/upload-status" },
    { "source": "/api/cron/upload-pipeline", "destination": "/api/cron/upload-pipeline" },
    { "source": "/api/cron/instagram-comments", "destination": "/api/cron/instagram-comments" },
    { "source": "/api/instagram-logs", "destination": "/api/instagram-logs" },
    { "source": "/api/zernio/post", "destination": "/api/zernio/post" },
    { "source": "/api/zernio/accounts", "destination": "/api/zernio/accounts" },
    { "source": "/api/cs/kakao-webhook", "destination": "/api/cs/kakao-webhook" },
    { "source": "/api/cs/daily-report", "destination": "/api/cs/daily-report" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
