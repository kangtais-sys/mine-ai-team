# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# Vercel Cron Secret (자동 생성 또는 직접 설정)
CRON_SECRET=your-cron-secret-here

# Google Service Account (Drive + YouTube API)
GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Drive - "MINE 업로드" 폴더 ID
# (폴더 URL에서 추출: https://drive.google.com/drive/folders/FOLDER_ID)
GOOGLE_DRIVE_UPLOAD_FOLDER_ID=your-folder-id-here

# TikTok API
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
