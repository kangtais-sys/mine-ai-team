# Claude API
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxx

# Vercel
CRON_SECRET=your-cron-secret-here
VERCEL_API_TOKEN=your-vercel-api-token        # Settings > Tokens에서 생성
VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxx            # .vercel/project.json에서 확인

# Google OAuth 2.0 (Cloud Console > APIs & Services > Credentials)
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxx
GOOGLE_REDIRECT_URI=https://mine-ai-team.vercel.app/api/auth/google-callback
GOOGLE_REFRESH_TOKEN=  # OAuth 완료 시 Vercel 환경변수에 자동 저장됨

# Google Service Account (OAuth 대신 사용할 경우)
# GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Google Drive - "MINE 업로드" 폴더 ID
GOOGLE_DRIVE_UPLOAD_FOLDER_ID=your-folder-id-here

# TikTok OAuth (TikTok Developer Portal > App)
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=https://mine-ai-team.vercel.app/api/auth/tiktok-callback
TIKTOK_ACCESS_TOKEN=  # OAuth 완료 시 Vercel 환경변수에 자동 저장됨
TIKTOK_REFRESH_TOKEN=  # OAuth 완료 시 Vercel 환경변수에 자동 저장됨

# Slack (api.slack.com/apps > Incoming Webhooks)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# CS 자동화 - 구글시트 (밀리밀리 CS 상담 현황)
CS_GOOGLE_SHEET_ID=your-google-sheet-id-here

# Instagram 댓글 자동화 - n8n webhook
N8N_INSTAGRAM_WEBHOOK_URL=https://your-n8n.app.n8n.cloud/webhook/xxx

# Upstash Redis (Vercel KV 대체, vercel integration add upstash)
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...
